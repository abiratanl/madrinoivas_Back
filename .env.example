# ==========================================
# Application Configuration
# ==========================================
APP_NAME="madri_db"
APP_DESCRIPTION="Web application for a chain of costume rental stores."
APP_AUTHOR="Abiratan Lopes de Sousa Email: abi.lopes.sousa@gmail.com"
APP_VERSION=1.0.0

# ==========================================
# Server Configuration
# ==========================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ==========================================
# Database Configuration (MySQL)
# ==========================================
# IF Node is running locally and MySQL in Docker -> use 'localhost'
# IF Node is running inside Docker -> use the service name (e.g., 'db_service' or 'mysql')
DB_HOST=127.0.0.1
DB_PORT_EXTERNAL=3307  # Change this for each new project

# Standard MySQL port
DB_PORT=3306

# Database credentials (Must match docker-compose environment variables)
DB_USER=root
DB_PASSWORD=********
DB_NAME=madri_db
DB_NAME_TEST=madri_test #If you make changes here, also make changes in init.sql.

# ==========================================
# Connection Pool Settings (Optional but recommended)
# ==========================================
DB_CONNECTION_LIMIT=10

# ==========================================
# Security (JWT & Hashing) - Future Proofing
# ==========================================
# Generate a strong random string for this
JWT_SECRET=******************************************
JWT_EXPIRES_IN=1h

# ==========================================
# Admin Seed Configuration (Initial User)
# ==========================================
# Used by the script 'src/scripts/createAdmin.js' (npm run seed:admin)
ADMIN_EMAIL=admin@madrinoivas.com.br
ADMIN_NAME=Super Administrador




